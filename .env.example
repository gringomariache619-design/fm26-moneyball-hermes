# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production

# Server
PORT=5000
HOST=0.0.0.0

# Database (optional)
DATABASE_URL=sqlite:///moneyball.db

# File Upload
MAX_CONTENT_LENGTH=52428800  # 50MB

# Tesseract OCR
TESSERACT_PATH=/usr/bin/tesseract  # Mac/Linux
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe  # Windows

# Railway (when deployed)
# RAILWAY_ENVIRONMENT_NAME=production
# RAILWAY_PROJECT_ID=your-project-id
# RAILWAY_DEPLOYMENT_ID=your-deployment-id

# Hermes Integration (optional)
# HERMES_WEBHOOK_SECRET=your-webhook-secret
# HERMES_API_KEY=your-api-key
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# Notion Integration (optional)
# NOTION_TOKEN=your-notion-api-key
# NOTION_DATABASE_ID=your-database-id

# Third-party APIs
# TRANSFERMARKT_API_KEY=your-key
# UNDERSTAT_API_KEY=your-key
